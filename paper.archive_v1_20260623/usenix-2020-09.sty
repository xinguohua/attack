% usenix-2020-09.sty - USENIX Security style (simplified)
% Based on the official USENIX template

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{usenix-2020-09}[2020/09/01 USENIX Security style]

% Page layout
\RequirePackage[letterpaper,left=1in,right=1in,top=1in,bottom=1in]{geometry}

% Font settings
\RequirePackage{mathptmx}  % Times Roman
\RequirePackage[scaled=0.90]{helvet}
\RequirePackage{courier}

% Section formatting
\RequirePackage{titlesec}
\titleformat{\section}{\large\bfseries}{\thesection}{1em}{}
\titleformat{\subsection}{\normalsize\bfseries}{\thesubsection}{1em}{}
\titleformat{\subsubsection}{\normalsize\itshape}{\thesubsubsection}{1em}{}

% Spacing
\titlespacing*{\section}{0pt}{12pt plus 2pt minus 2pt}{6pt plus 1pt minus 1pt}
\titlespacing*{\subsection}{0pt}{8pt plus 2pt minus 2pt}{4pt plus 1pt minus 1pt}

% Caption formatting
\RequirePackage{caption}
\captionsetup{font=small,labelfont=bf}

% Footnote formatting
\renewcommand{\footnoterule}{\kern-3pt \hrule width 0.4\columnwidth \kern 2.6pt}

% No page numbers for submission
% \pagestyle{plain}
\pagestyle{plain}

% Adjust paragraph spacing
\setlength{\parindent}{1em}
\setlength{\parskip}{0pt}

% Float parameters
\renewcommand{\topfraction}{0.9}
\renewcommand{\bottomfraction}{0.9}
\renewcommand{\textfraction}{0.1}
\renewcommand{\floatpagefraction}{0.8}

\endinput
