# Local historical notes kept outside the active code path.
pids_attack/p3_implementation_plan.archive_pre_refactor.md

# Guard against accidentally creating nested project copies under experiments.
pids_attack/experiments/*/pids_attack/

# Upstream baseline clones are huge pristine third-party repositories. Keep our
# wrappers under baselines/pipelines/ trackable, but ignore generated outputs.
baselines/provninja/
baselines/contorter/
baselines/goyal/
baselines/pipelines/*/diffs/
baselines/pipelines/*/results/
baselines/pipelines/*/judgments/
baselines/pipelines/**/*.json

# Vendored upstream clone has its own git remote and local patches. Manage it
# with its own git checkout unless we deliberately convert it to a submodule.
pids_attack/PIDSMaker/

# LaTeX build byproducts.
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
